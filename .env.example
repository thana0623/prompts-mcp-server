# Target project root (default: current working directory)
PROJECT_ROOT=

# Prompts subdirectory (relative to project root)
PROMPTS_SUBDIR=.github/prompts

# AI assistant type (claude-code, cline, cursor, windsurf, copilot, continue)
ASSISTANT=claude-code

# MCP Server name and version
MCP_SERVER_NAME=prompts-mcp-server
MCP_SERVER_VERSION=1.0.0

# Auto git commit after log_dialog (default: true)
AUTO_COMMIT=true
